DB_HOST=localhost
DB_PORT=3306
DB_USER=koop
DB_PASSWORD=koop
DB_DATABASE=kooperative

# Session signing — MUST be overridden in stage/prod
SESSION_SECRET=dev-only-do-not-use-in-prod-please-change-me-now

# SMTP (defaults match the local maildev container)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=

MAIL_FROM=shop@kooperative.de
MAIL_OPERATOR=shop@kooperative.de

# Optional: deep-link target for the mail's "Im Admin öffnen" button
# ADMIN_BASE_URL=https://shop.kooperative.de/admin

# Toggle for write protection (default: true; set to false to enforce read-only mode in stage)
ALLOW_DB_WRITES=true
